{
    "model_dir": "/path/to/your/oga/model",
    "package_dir": "/path/to/your/package",
    "therock_dist": "/path/to/therock",

    "genai_configs": {
        "morphizen": {
            "2048": "genai_config_morphizen_2k.json"
        },
        "dml": {
            "2048": "genai_config_dml_2k.json"
        },
        "cpu": {
            "2048": "genai_config_cpu_2k.json"
        }
    },

    "tests": {
        "PPL": {
            "eps": ["morphizen", "dml", "cpu"],
            "seq_lengths": [2048],
            "params": {
                "nsamples": 0.02
            }
        },
        "MMLU": {
            "eps": ["morphizen", "dml", "cpu"],
            "seq_lengths": [2048],
            "params": {}
        },
        "RUNMODEL": {
            "eps": ["morphizen"],
            "seq_lengths": [2048],
            "params": {
                "prompt_file": "prompts.json",
                "max_new_tokens": 128
            }
        }
    }
}
